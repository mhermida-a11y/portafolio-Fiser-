// Café especial — también seleccionable
(function(){
  const el = document.getElementById('g-cafe');
  CAFE.forEach(p => {
    const c = document.createElement('div');
    c.className = 'cafe-card';
    c.dataset.sku = p.sku;
    c.onclick = () => {
      c.classList.toggle('selected', !seleccion.has(p.sku));
      toggleSeleccion(p.sku, p);
    };
    if (p.isNew) {
      const nb = document.createElement('span');
      nb.className = 'cafe-new';
      nb.textContent = 'Novedad';
      c.appendChild(nb);
    }
    const imgDiv = document.createElement('div');
    imgDiv.className = 'cafe-img';
    if (p.img) {
      const img = document.createElement('img');
      img.src = p.img; img.alt = p.name; img.loading = 'lazy';
      img.style.cssText = 'width:100%;height:100%;object-fit:contain;padding:4px';
      imgDiv.appendChild(img);
    }
    c.appendChild(imgDiv);
    const info = document.createElement('div');
    info.innerHTML = `<div class="cafe-brand">${p.brand}</div><div class="cafe-name">${p.name}</div><div class="cafe-price">${cop(p.price)}</div>`;
    c.appendChild(info);
    el.appendChild(c);
  });
})();

// Total refs
const base = AGUAS.length+BEBIDAS_HATSU.length+BEBIDAS_OTROS.length+ZUMO.length+
  GALL_FIT.length+GALL_GULLON.length+GALL_MAD.length+GALL_OLU.length+
  SNACKS_FIT.length+SNACKS_NATIF.length+SNACKS_OTROS.length+
  FRUTOS_FIT.length+FRUTOS_ALARA.length+FRUTOS_OTROS.length+FRUTOS_PISTACHO_MARANON.length+
  LECHES_ALPINA.length+LECHES_ALMENDROLA.length+CONDIMENTOS.length+CAFE.length;
document.getElementById('total-refs').textContent = base + ' + ' + (HELADOS_OLU.length+HELADOS_OTROS.length) + ' eventos';

// Nav scroll
const secs = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-a');
window.addEventListener('scroll', () => {
  let cur = '';
  secs.forEach(s => { if(window.scrollY >= s.offsetTop - 80) cur = s.id; });
  navLinks.forEach(a => a.classList.toggle('on', a.getAttribute('href') === '#'+cur));
}, {passive:true});
</script>
</body>
</html>
