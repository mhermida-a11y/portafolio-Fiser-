<script>
const PEDIDO_MIN = 1000000;
const TIENDA = 'STF 15 - Usaquén, Bogotá';
const CLIENTE = 'Fiserv Colombia Limitada';
const NIT = '830.094.425-0';

function cop(p){return '$'+Math.round(p).toLocaleString('es-CO')}

// Selección
const seleccion = new Map(); // sku -> producto

function toggleSeleccion(sku, producto) {
  if (seleccion.has(sku)) {
    seleccion.delete(sku);
  } else {
    seleccion.set(sku, producto);
  }
  actualizarBarra();
  // Actualizar visual de la card
  document.querySelectorAll('[data-sku="'+sku+'"]').forEach(el => {
    el.classList.toggle('selected', seleccion.has(sku));
    const hint = el.querySelector('.sel-hint');
    if (hint) hint.textContent = seleccion.has(sku) ? '✓ Seleccionado' : 'Clic para seleccionar';
  });
}

function actualizarBarra() {
  const n = seleccion.size;
  const total = [...seleccion.values()].reduce((s,p) => s + p.price, 0);
  document.getElementById('sel-count').textContent = n + (n===1?' producto seleccionado':' productos seleccionados');
  document.getElementById('sel-total').textContent = 'Total: ' + cop(total);
  document.getElementById('sel-bar').classList.toggle('visible', n > 0);
}

function limpiarSeleccion() {
  seleccion.clear();
  document.querySelectorAll('.card.selected, .cafe-card.selected').forEach(el => el.classList.remove('selected'));
  document.querySelectorAll('.sel-hint').forEach(el => el.textContent = 'Clic para seleccionar');
  actualizarBarra();
}

function calcularCantidad(price, totalProductos) {
  // Cantidad mínima para superar el pedido mínimo distribuida entre los productos
  const porProducto = Math.ceil(PEDIDO_MIN / totalProductos / price);
  return Math.max(1, porProducto);
}

function descargarExcel() {
  if (seleccion.size === 0) return;
  const prods = [...seleccion.values()];
  const totalProductos = prods.length;

  const filas = prods.map(p => {
    const qty = calcularCantidad(p.price, totalProductos);
    return {
      'Tienda': TIENDA,
      'Nombre del cliente': CLIENTE,
      'NIT del cliente': NIT,
      'SKU': p.sku,
      'Nombre del producto': p.name,
      'Categoría': p.cat,
      'Precio (con IVA)': p.price,
      'Cantidad sugerida': qty
    };
  });

  const totalPedido = prods.reduce((s,p) => {
    const qty = calcularCantidad(p.price, totalProductos);
    return s + p.price * qty;
  }, 0);

  // Crear workbook
  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.json_to_sheet(filas);

  // Ancho de columnas
  ws['!cols'] = [
    {wch:28}, {wch:28}, {wch:18}, {wch:14}, {wch:45},
    {wch:20}, {wch:18}, {wch:18}
  ];

  // Fila de resumen al final
  const lastRow = filas.length + 2;
  XLSX.utils.sheet_add_aoa(ws, [
    [''],
    ['Total pedido estimado:', '', '', '', '', '', '', cop(totalPedido)],
    ['Pedido mínimo requerido:', '', '', '', '', '', '', cop(PEDIDO_MIN)],
  ], {origin: lastRow});

  XLSX.utils.book_append_sheet(wb, ws, 'Preselección');
  XLSX.writeFile(wb, 'Preseleccion_Fiserv_Colombia_Fithub.xlsx');
}

// Construir cards
function makeCard(p, brandCls, isNew) {
  const card = document.createElement('div');
  card.className = 'card';
  card.dataset.sku = p.sku;
  card.onclick = () => toggleSeleccion(p.sku, p);

  if (isNew) {
    const r = document.createElement('span');
    r.className = 'card-new-ribbon';
    r.textContent = 'Novedad';
    card.appendChild(r);
  }

  const imgWrap = document.createElement('div');
  imgWrap.className = 'card-img';
  if (p.img) {
    const img = document.createElement('img');
    img.src = p.img; img.alt = p.name; img.loading = 'lazy';
    img.onerror = function() {
      this.style.display = 'none';
      const ph = document.createElement('div');
      ph.className = 'no-img';
      ph.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg><span>Sin imagen</span>';
      imgWrap.appendChild(ph);
    };
    imgWrap.appendChild(img);
  }
  card.appendChild(imgWrap);

  const body = document.createElement('div');
  body.className = 'card-body';
  body.innerHTML = `
    <div class="cb-brand ${brandCls}">${p.brand}</div>
    <div class="cb-name">${p.name}</div>
    <div class="cb-foot">
      <div><span class="price-l">precio c/IVA</span><span class="price-v">${cop(p.price)}</span></div>
      <a class="card-link" href="https://fithub.com.co/p/${p.slug}" target="_blank" onclick="event.stopPropagation()">Ver →</a>
    </div>`;
  card.appendChild(body);

  const hint = document.createElement('div');
  hint.className = 'sel-hint';
  hint.textContent = 'Clic para seleccionar';
  card.appendChild(hint);

  return card;
}

function buildGrid(id, products, brandCls, cntId) {
  const el = document.getElementById(id);
  products.forEach(p => el.appendChild(makeCard(p, brandCls||'br-or', p.isNew||false)));
  if (cntId) document.getElementById(cntId).textContent = products.length+' SKUs';
}
function buildMixed(id, groups, cntId) {
  const el = document.getElementById(id);
  let total = 0;
  groups.forEach(({prods,cls}) => { prods.forEach(p => { el.appendChild(makeCard(p,cls,p.isNew||false)); total++; }); });
  if (cntId) document.getElementById(cntId).textContent = total+' SKUs';
}

