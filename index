<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portafolio Fiserv Colombia · Fithub</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --or:#EC6412;--or-l:#fdf0e8;--or-d:#c44f0a;
  --gn:#2D593B;--gn-l:#eaf3ed;--gn-d:#1e3d28;
  --lv:#C2BFE1;--lv-l:#f0eff9;
  --yw:#F7EE7E;--yw-d:#d4c93a;
  --wh:#fff;--cr:#FAFAF5;--tx:#1a1a1a;--mu:#6b7280;--bd:#e5e7eb;
}
body{font-family:'Montserrat',sans-serif;background:var(--cr);color:var(--tx);-webkit-print-color-adjust:exact;print-color-adjust:exact}

.hdr{background:var(--gn);color:var(--wh);padding:32px 40px 26px;position:relative;overflow:hidden}
.hdr::after{content:'';position:absolute;top:-80px;right:-80px;width:340px;height:340px;border-radius:50%;background:rgba(255,255,255,.04);pointer-events:none}
.hdr-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px}
.logo{display:flex;align-items:center;gap:12px}
.logo-box{width:36px;height:36px;background:var(--or);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.logo-box svg{width:20px;height:20px;fill:#fff}
.logo-name{font-size:14px;font-weight:800;color:#fff;letter-spacing:.1em;text-transform:uppercase}
.logo-sub{font-size:10px;color:rgba(255,255,255,.5);margin-top:1px}
.hdr-badge{background:var(--or);color:#fff;font-size:10px;font-weight:700;padding:5px 12px;border-radius:20px;letter-spacing:.07em;text-transform:uppercase}
.hdr-eye{font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.4);margin-bottom:5px}
.hdr-name{font-size:24px;font-weight:800;color:#fff;margin-bottom:10px;line-height:1.1}
.hdr-pills{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:20px}
.pill{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:4px 12px;font-size:11px;font-weight:500;color:rgba(255,255,255,.8)}
.hdr-line{height:1px;background:rgba(255,255,255,.12);margin-bottom:16px}
.hdr-stats{display:flex;flex-wrap:wrap;gap:22px}
.stat{display:flex;flex-direction:column;gap:2px}
.stat-v{font-size:17px;font-weight:700;color:#fff}
.stat-l{font-size:9px;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.4)}
.stat-sep{width:1px;background:rgba(255,255,255,.12);align-self:stretch}

.nav{background:#fff;border-bottom:1px solid var(--bd);position:sticky;top:0;z-index:100}
.nav-inner{max-width:1200px;margin:0 auto;padding:0 32px;display:flex;overflow-x:auto;gap:2px;scrollbar-width:none}
.nav-inner::-webkit-scrollbar{display:none}
.nav-a{padding:12px 14px;font-size:10px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--mu);white-space:nowrap;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;text-decoration:none;flex-shrink:0}
.nav-a:hover,.nav-a.on{color:var(--or);border-bottom-color:var(--or)}

.main{max-width:1200px;margin:0 auto;padding:30px 40px 100px}

.obar{background:var(--yw);border:1px solid var(--yw-d);border-radius:12px;padding:13px 20px;display:flex;align-items:center;gap:12px;margin-bottom:28px}
.obar-txt{font-size:12px;font-weight:600;color:var(--gn-d)}
.obar-val{margin-left:auto;font-size:15px;font-weight:800;color:var(--gn-d)}

.sec{margin-bottom:40px}
.sec-head{display:flex;align-items:center;gap:12px;margin-bottom:18px}
.sec-ico{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.ico-or{background:var(--or-l);color:var(--or)}
.ico-gn{background:var(--gn-l);color:var(--gn)}
.ico-lv{background:var(--lv-l);color:#5a55a0}
.ico-yw{background:#fffde0;color:#7a6f00}
.sec-title{font-size:16px;font-weight:700;color:var(--tx)}
.sec-sub{font-size:11px;color:var(--mu);margin-top:1px}
.sec-line{flex:1;height:1px;background:var(--bd)}
.sec-cnt{font-size:11px;font-weight:600;color:var(--mu);white-space:nowrap}

.card-new-ribbon{position:absolute;top:10px;right:10px;z-index:2;background:var(--or);color:#fff;font-size:8px;font-weight:800;padding:2px 8px;border-radius:8px;letter-spacing:.06em;text-transform:uppercase}

.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(172px,1fr));gap:13px}

/* CARD — seleccionable */
.card{background:#fff;border-radius:12px;overflow:hidden;border:1.5px solid var(--bd);transition:transform .18s,box-shadow .18s,border-color .15s;display:flex;flex-direction:column;position:relative;cursor:pointer}
.card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.09)}
.card.selected{border-color:var(--or);box-shadow:0 0 0 3px rgba(236,100,18,.18)}
.card.selected .card-img::after{content:'✓';position:absolute;top:8px;left:8px;width:22px;height:22px;background:var(--or);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;z-index:3}
.sel-hint{position:absolute;bottom:0;left:0;right:0;background:var(--or);color:#fff;font-size:9px;font-weight:700;text-align:center;padding:4px;letter-spacing:.04em;opacity:0;transition:opacity .15s}
.card:hover .sel-hint{opacity:1}
.card.selected .sel-hint{opacity:1;background:var(--gn)}

.card-img{width:100%;aspect-ratio:1;background:var(--cr);display:flex;align-items:center;justify-content:center;overflow:hidden;padding:10px;position:relative}
.card-img img{width:100%;height:100%;object-fit:contain;border-radius:4px}
.no-img{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;opacity:.2}
.no-img svg{width:24px;height:24px}
.no-img span{font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:.06em}
.card-body{padding:10px 12px 22px;flex:1;display:flex;flex-direction:column;border-top:1px solid var(--bd)}
.cb-brand{font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;margin-bottom:3px}
.br-or{color:var(--or)} .br-gn{color:var(--gn)} .br-lv{color:#5a55a0} .br-yw{color:#7a6f00}
.cb-name{font-size:11px;font-weight:600;color:var(--tx);line-height:1.35;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;min-height:30px;flex:1}
.cb-foot{display:flex;align-items:flex-end;justify-content:space-between;margin-top:9px;gap:5px}
.price-l{font-size:8px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--mu);display:block;margin-bottom:1px}
.price-v{font-size:14px;font-weight:800;color:var(--tx)}
.card-link{font-size:9px;font-weight:700;color:var(--gn);text-decoration:none;padding:4px 7px;border-radius:6px;background:var(--gn-l);border:1px solid #c5ddc9;white-space:nowrap;flex-shrink:0}
.card-link:hover{background:var(--gn);color:#fff}

.cafe-row{display:grid;grid-template-columns:1fr 1fr;gap:13px;max-width:480px}
.cafe-card{background:#fff;border-radius:12px;border:1.5px solid var(--bd);display:flex;align-items:center;gap:12px;padding:13px;position:relative;transition:border-color .15s,box-shadow .15s;cursor:pointer}
.cafe-card:hover{box-shadow:0 8px 24px rgba(0,0,0,.09)}
.cafe-card.selected{border-color:var(--or);box-shadow:0 0 0 3px rgba(236,100,18,.18)}
.cafe-img{width:68px;height:68px;background:var(--cr);border-radius:9px;overflow:hidden;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.cafe-img img{width:100%;height:100%;object-fit:contain;padding:4px}
.cafe-new{position:absolute;top:8px;right:8px;background:var(--or);color:#fff;font-size:8px;font-weight:800;padding:2px 7px;border-radius:7px;letter-spacing:.06em;text-transform:uppercase}
.cafe-brand{font-size:9px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;color:var(--or);margin-bottom:3px}
.cafe-name{font-size:12px;font-weight:700;color:var(--tx);line-height:1.3;margin-bottom:5px}
.cafe-price{font-size:14px;font-weight:800;color:var(--tx)}

.sec-ice{background:linear-gradient(135deg,var(--gn-d) 0%,var(--gn) 100%);border-radius:18px;padding:26px;position:relative;overflow:hidden}
.sec-ice::before{content:'';position:absolute;top:-50px;right:-60px;width:250px;height:250px;border-radius:50%;background:rgba(255,255,255,.04);pointer-events:none}
.sec-ice .sec-title{color:#fff}
.sec-ice .sec-sub{color:rgba(255,255,255,.55)}
.sec-ice .sec-line{background:rgba(255,255,255,.2)}
.sec-ice .sec-cnt{color:rgba(255,255,255,.45)}
.sec-ice .sec-ico{background:rgba(255,255,255,.12);color:#fff}
.ice-badge{background:var(--yw);color:var(--gn-d);font-size:9px;font-weight:800;padding:2px 9px;border-radius:8px;letter-spacing:.05em;text-transform:uppercase;margin-left:8px}
.sec-ice .card{background:rgba(255,255,255,.96);border-color:rgba(255,255,255,.15)}
.sec-ice .card.selected{border-color:var(--yw);box-shadow:0 0 0 3px rgba(247,238,126,.3)}
.ice-grid{position:relative;z-index:1}

/* BARRA FLOTANTE DE SELECCIÓN */
.sel-bar{position:fixed;bottom:0;left:0;right:0;background:var(--gn-d);color:#fff;padding:14px 40px;display:flex;align-items:center;gap:16px;z-index:300;transform:translateY(100%);transition:transform .25s ease;box-shadow:0 -4px 24px rgba(0,0,0,.25)}
.sel-bar.visible{transform:translateY(0)}
.sel-bar-info{display:flex;flex-direction:column;gap:2px}
.sel-bar-count{font-size:13px;font-weight:700}
.sel-bar-total{font-size:11px;color:rgba(255,255,255,.6)}
.sel-bar-btns{margin-left:auto;display:flex;gap:10px;align-items:center}
.btn-clear{padding:8px 16px;font-size:12px;font-weight:600;border-radius:8px;border:1px solid rgba(255,255,255,.3);background:transparent;color:#fff;cursor:pointer;font-family:'Montserrat',sans-serif;transition:background .15s}
.btn-clear:hover{background:rgba(255,255,255,.1)}
.btn-excel{padding:10px 20px;font-size:13px;font-weight:700;border-radius:10px;border:none;background:var(--or);color:#fff;cursor:pointer;font-family:'Montserrat',sans-serif;display:flex;align-items:center;gap:8px;transition:background .15s;white-space:nowrap}
.btn-excel:hover{background:var(--or-d)}

@media(max-width:580px){
  .hdr,.main{padding:20px 16px}
  .nav-inner{padding:0 12px}
  .grid{grid-template-columns:repeat(2,1fr);gap:10px}
  .cafe-row{grid-template-columns:1fr}
  .stat-sep{display:none}
  .sel-bar{padding:12px 16px;flex-wrap:wrap;gap:10px}
  .sel-bar-btns{margin-left:0;width:100%}
  .btn-excel{flex:1;justify-content:center}
}
</style>
</head>
